{
  "name": "kailendar",
  "description": "A flexible React calendar component library with multiple views.",
  "version": "0.0.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/PiyushXCoder/kailendar"
  },
  "homepage": "https://kailendar.surge.sh/",
  "bugs": {
    "url": "https://github.com/PiyushXCoder/kailendar/issues"
  },
  "type": "module",
  "main": "./dist/kailendar.umd.cjs",
  "module": "./dist/kailendar.js",
  "exports": {
    ".": {
      "import": "./dist/kailendar.js",
      "require": "./dist/kailendar.umd.cjs",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "sass": "^1.99.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-svgr": "^5.2.0"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  }
}
